# .env.example — Copy this to .env and fill in your API keys.
# Do NOT commit your actual .env file (it is gitignored).

# [Required] OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# [Optional] Tavily API key — needed only for the web_search tool.
# Get yours at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# [Production only] Restrict CORS to your frontend domain.
# Leave unset or set to "*" for local development.
# CORS_ORIGINS=https://yourapp.com
